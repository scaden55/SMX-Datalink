# Environment
NODE_ENV=development

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
MAX_BODY_SIZE=1mb

# SimConnect (set to false for Linux/VPS server deployment)
SIMCONNECT_ENABLED=true
SIMCONNECT_POLL_INTERVAL=1000
SIMCONNECT_RECONNECT_INTERVAL=5000

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database
DB_PATH=./data/acars.db

# SimBrief
SIMBRIEF_API_KEY=

# VATSIM
VATSIM_ENABLED=true
VATSIM_POLL_INTERVAL=15000
VATSIM_DATA_URL=https://data.vatsim.net/v3/vatsim-data.json
VATSIM_TRANSCEIVERS_URL=https://data.vatsim.net/v3/transceivers-data.json
