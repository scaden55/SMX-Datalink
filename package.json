{
  "name": "acars-system",
  "version": "1.0.1",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend",
    "electron"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:electron": "npm run build -w electron && npm run dev -w electron",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "build:shared": "npm run build -w shared",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "build:electron": "npm run build -w electron",
    "build": "npm run build:shared && concurrently \"npm run build:backend\" \"npm run build:frontend\" \"npm run build:electron\"",
    "package": "npm run build && npm run package -w electron",
    "package:dir": "npm run build && npm run package:dir -w electron",
    "postinstall": "node -e \"require('rcedit').rcedit(require('path').join('node_modules','electron','dist','electron.exe'),{icon:'electron/assets/icon.ico'}).then(()=>console.log('rcedit: icon stamped on electron.exe')).catch(e=>console.warn('rcedit skipped:',e.message))\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "semver": "^7.7.4"
  }
}
